    "migrate:remote": "wrangler d1 migrations apply chaichat --remote"
  },
  "dependencies": {
    "hono": "^4.10.0",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "wrangler": "^4.99.0"
  }
}
